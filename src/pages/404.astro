---
import PageLayout from "@layouts/404Layout.astro"
import TopLayout from "@layouts/TopLayout.astro";
---
<PageLayout title="Page not found">
  <TopLayout>
    <div class="relative bg-white dark:bg-black">
      <div class="mx-auto max-w-screen-sm">

        <!-- 404 Section -->
        <section class="animate relative w-full h-full flex items-center justify-center">
          <article class="p-5">
            <h1>404 Not Found</h1>
            <div class="canvas">
              <svg viewBox="0 0 500 400" xmlns="http://www.w3.org">
                <!-- Lubang Es & Air -->
                <ellipse cx="150" cy="350" rx="60" ry="20" fill="#E0F7FA" />
                <circle class="ripple" cx="150" cy="350" r="10" fill="none" stroke="#4DD0E1" stroke-width="2" />
                
                <!-- Badan Yeti (Sederhana) -->
                <circle cx="350" cy="250" r="80" fill="#4FC3F7" />
                <circle cx="350" cy="200" r="60" fill="#81D4FA" />
                
                <!-- Joran Pancing -->
                <g class="fishing-rod">
                  <line x1="320" y1="260" x2="150" y2="150" stroke="#FFB74D" stroke-width="8" stroke-linecap="round" />
                  <line class="fishing-line" x1="150" y1="150" x2="150" y2="350" stroke="#26C6DA" stroke-width="2" />
                  <circle class="bobber" cx="150" cy="350" r="8" fill="#EF5350" />
                </g>
              </svg>
            </div>
            <p>Maaf, halaman yang Anda cari tidak ada.</p>
            <button id="back-to-home" aria-label="Back to top of page" class="group flex w-fit p-1.5 gap-1.5 text-sm items-center border rounded hover:bg-black/5 hover:dark:bg-white/10 border-black/15 dark:border-white/20 transition-colors duration-300 ease-in-out">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="stroke-current group-hover:stroke-black group-hover:dark:stroke-white rotate-50"> <line x1="19" y1="12" x2="5" y2="12" class="scale-x-0 group-hover:scale-x-100 translate-x-3 group-hover:translate-x-0 transition-all duration-300 ease-in-out"></line> <polyline points="12 19 5 12 12 5" class="translate-x-1 group-hover:translate-x-0 transition-all duration-300 ease-in-out"></polyline> </svg>
              <div class="w-full group-hover:text-black group-hover:dark:text-white transition-colors duration-300 ease-in-out">
              <a href="/" style="text-decoration:none">Back to home</a>
              </div>
            </button>
          </article>
        </section>
      </div>
    </div>
  </TopLayout>
</PageLayout>
